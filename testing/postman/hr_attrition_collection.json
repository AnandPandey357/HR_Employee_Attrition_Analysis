          }
        }
      ]
    },
    {
      "name": "Filter Employees by Department",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/employees?department=Sales",
          "host": ["{{base_url}}"],
          "path": ["employees"],
          "query": [
            {
              "key": "department",
              "value": "Sales"
            }
          ]
        },
        "description": "Get employees filtered by department"
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"All employees are from Sales department\", function () {",
              "    var jsonData = pm.response.json();",
              "    jsonData.data.forEach(function(emp) {",
              "        pm.expect(emp.Department).to.eql('Sales');",
              "    });",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Filter Employees by Attrition Status",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/employees?attrition=Yes",
          "host": ["{{base_url}}"],
          "path": ["employees"],
          "query": [
            {
              "key": "attrition",
              "value": "Yes"
            }
          ]
        },
        "description": "Get employees filtered by attrition status"
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"All employees have Attrition=Yes\", function () {",
              "    var jsonData = pm.response.json();",
              "    jsonData.data.forEach(function(emp) {",
              "        pm.expect(emp.Attrition).to.eql('Yes');",
              "    });",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Attrition Statistics",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/attrition-stats",
          "host": ["{{base_url}}"],
          "path": ["attrition-stats"]
        },
        "description": "Get comprehensive attrition statistics"
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response has overall stats\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('overall');",
              "    pm.expect(jsonData.overall).to.have.property('attrition_rate');",
              "});",
              "",
              "pm.test(\"Response has department stats\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('by_department');",
              "});",
              "",
              "pm.test(\"Response has overtime impact\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('overtime_impact');",
              "});",
              "",
              "pm.test(\"Attrition rate is between 0 and 100\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.overall.attrition_rate).to.be.at.least(0);",
              "    pm.expect(jsonData.overall.attrition_rate).to.be.at.most(100);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Get KPI Metrics",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/kpi-metrics",
          "host": ["{{base_url}}"],
          "path": ["kpi-metrics"]
        },
        "description": "Get key performance indicators"
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response has total_employees\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('total_employees');",
              "    pm.expect(jsonData.total_employees).to.be.a('number');",
              "});",
              "",
              "pm.test(\"Response has attrition_rate\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('attrition_rate');",
              "});",
              "",
              "pm.test(\"Response has average_salary\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('average_salary');",
              "});",
              "",
              "pm.test(\"All KPI values are valid\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.total_employees).to.be.above(0);",
              "    pm.expect(jsonData.average_salary).to.be.above(0);",
              "    pm.expect(jsonData.average_age).to.be.above(0);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Department Statistics",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/department-stats",
          "host": ["{{base_url}}"],
          "path": ["department-stats"]
        },
        "description": "Get statistics by department"
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response contains department data\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(Object.keys(jsonData).length).to.be.above(0);",
              "});",
              "",
              "pm.test(\"Each department has required fields\", function () {",
              "    var jsonData = pm.response.json();",
              "    Object.keys(jsonData).forEach(function(dept) {",
              "        pm.expect(jsonData[dept]).to.have.property('total_employees');",
              "        pm.expect(jsonData[dept]).to.have.property('average_salary');",
              "        pm.expect(jsonData[dept]).to.have.property('attrition_rate');",
              "    });",
              "});"
            ]
          }
        }
      ]
    },
