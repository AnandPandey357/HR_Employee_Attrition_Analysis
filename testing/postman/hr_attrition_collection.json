{
  "info": {
    "name": "HR Employee Attrition API Collection",
    "description": "Postman collection for testing HR Employee Attrition Analysis API endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "hr-attrition-api-collection",
    "version": {
      "major": 1,
      "minor": 0,
      "patch": 0
    }
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "API Home",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/",
          "host": ["{{base_url}}"],
          "path": [""]
        },
        "description": "Get API information and available endpoints"
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response has message field\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('message');",
              "});",
              "",
              "pm.test(\"Response has endpoints field\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('endpoints');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Get All Employees",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/employees",
          "host": ["{{base_url}}"],
          "path": ["employees"]
        },
        "description": "Get all employee records"
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response has data array\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('data');",
              "    pm.expect(jsonData.data).to.be.an('array');",
              "});",
              "",
              "pm.test(\"Response has total count\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('total');",
              "    pm.expect(jsonData.total).to.be.a('number');",
              "});",
              "",
              "pm.test(\"Employee data has required fields\", function () {",
              "    var jsonData = pm.response.json();",
              "    if (jsonData.data.length > 0) {",
              "        pm.expect(jsonData.data[0]).to.have.property('EmployeeID');",
              "        pm.expect(jsonData.data[0]).to.have.property('Age');",
              "        pm.expect(jsonData.data[0]).to.have.property('Department');",
              "        pm.expect(jsonData.data[0]).to.have.property('Attrition');",
              "    }",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Employee by ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/employees/EMP001",
          "host": ["{{base_url}}"],
          "path": ["employees", "EMP001"]
        },
        "description": "Get a specific employee by ID"
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response has EmployeeID\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('EmployeeID');",
              "    pm.expect(jsonData.EmployeeID).to.eql('EMP001');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Get Employee by Invalid ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/employees/INVALID999",
          "host": ["{{base_url}}"],
          "path": ["employees", "INVALID999"]
        },
        "description": "Test edge case: Get employee with invalid ID"
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
